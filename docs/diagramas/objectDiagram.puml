}

object "questao2: Question" as questao2 {
  id = 31
  enunciado = "Explique dominio e imagem"
  peso = 1.0
  idActivity = 20
}

usuarioProfessor -- professorAna : especializa
usuarioAluno -- alunoJoao : especializa
professorAna -- matematica : ministra
alunoJoao -- matriculaJoao : realiza
matematica -- matriculaJoao : recebe
