@startuml
title Diagrama de Objetos - Sistema TobIAs

skinparam object {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #475569
}

object "usuarioProfessor: User" as usuarioProfessor {
  id = 1
  name = "Ana Souza"
  cpf = 12345678901
